# Smart Campus Hub - Environment Configuration Template
# Copy this file to .env and fill in the required values
# This file is safe to commit to version control (contains no secrets)

# ===== SERVER CONFIGURATION =====
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# ===== DATABASE CONFIGURATION =====
# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=dbname
SPRING_DATA_MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=smartcampus
SPRING_DATA_MONGODB_DATABASE=smartcampus

# ===== JWT CONFIGURATION =====
# Secret key for signing JWT tokens (minimum 32 characters)
# Generate with: openssl rand -base64 32
# Keep this secret and change it in production!
APP_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
APP_JWT_EXPIRATION=86400000

# ===== OAUTH2 CONFIGURATION =====
# Get these credentials from Google Cloud Console (https://console.cloud.google.com)
# 1. Create a new OAuth2 Client ID
# 2. Set Authorized Redirect URIs: http://localhost:8080/api/login/oauth2/code/google
# 3. Copy Client ID and Secret here
OAUTH2_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH2_GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== CORS CONFIGURATION =====
# Allow requests from these origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept
CORS_ALLOW_CREDENTIALS=true

# ===== APPLICATION ENVIRONMENT =====
# Values: development, staging, production
APP_ENVIRONMENT=development

# ===== LOGGING CONFIGURATION =====
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SMARTCAMPUS=DEBUG

# ===== ACTUATOR CONFIGURATION (Monitoring) =====
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# ===== EMAIL CONFIGURATION (Optional - for future email notifications) =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@smartcampus.com
MAIL_SUBJECT_PREFIX=[SmartCampus]

# ===== OPTIONAL FEATURES =====
# Enable/Disable features
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_FILE_UPLOAD=true
FEATURE_REAL_TIME_NOTIFICATIONS=false

# File upload configuration
FILE_UPLOAD_MAX_SIZE=5242880
FILE_UPLOAD_PATH=/uploads/attachments

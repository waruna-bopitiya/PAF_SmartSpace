# Smart Campus Hub - Frontend Environment Configuration
# This file contains configuration for the React frontend

# ===== API CONFIGURATION =====
REACT_APP_API_BASE_URL=http://localhost:8080/api
REACT_APP_API_TIMEOUT=30000

# ===== OAUTH2 CONFIGURATION =====
# Google OAuth2 Client ID (same as backend)
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ===== APPLICATION NAME =====
REACT_APP_NAME=Smart Campus Hub
REACT_APP_VERSION=1.0.0

# ===== FEATURE FLAGS =====
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_REAL_TIME_UPDATES=false
REACT_APP_ENABLE_ANALYTICS=false

# ===== DEVELOPMENT =====
SKIP_PREFLIGHT_CHECK=true

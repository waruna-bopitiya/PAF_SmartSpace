# --- OS Specific Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db

# --- IDE & Editor Specific ---
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.factorypath
*.swp
*.swo
*~
bin/

# --- Node / Frontend Specific ---
node_modules/
/frontend/node_modules/
/frontend/build/
/frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# --- Java / Maven Specific ---


*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
/backend/compile.log
/backend/compile_output.txt

# --- Logs & Databases ---
*.log
*.sql
*.sqlite
*.db
/backend/*.log
/frontend/*.log

# --- Environment Secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
/backend/.env
/frontend/.env

# --- Miscellaneous ---
tmp/
temp/